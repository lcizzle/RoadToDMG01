---
# Note: The contents of this file are automatically generated.
# Any changes made by hand may be overwritten.
version: '0.2'
work_dir: .
design_root_dir: ../src
simulations:
  - name: Sim Modules Buffer Gate 01
    options: >-
      -top work.m_buffer_gate_01_tb -L dut +acc+b -waves
      waves/m_buffer_gate_01_tb_waves.mxd -l logs/m_buffer_gate_01_tb_dsim.log
  - name: Sim Modules Inverter Gate 01
    options: >-
      -top work.m_inverter_gate_01_tb -L dut +acc+b -waves
